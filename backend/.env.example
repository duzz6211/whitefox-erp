ENVIRONMENT=development
DATABASE_URL=sqlite:///./whitefox.db
# 프로덕션에서는 반드시 변경: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 프로덕션 전용 ──

# Supabase PostgreSQL
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# Cloudflare R2 (S3 호환 스토리지)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=whitefox-erp-files
# R2_PUBLIC_URL=https://files.teamduzz.com
